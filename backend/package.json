{
  "name": "cafe-backend",
  "version": "1.0.0",
  "description": "Backend server for Cafe app",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "build": "echo 'No build step required for Node.js backend' && exit 0",
    "postinstall": "echo 'Backend dependencies installed successfully'",
    "start:secure": "node start-secure.js",
    "dev": "nodemon server.js",
    "dev:secure": "nodemon start-secure.js",
    "security-check": "node -e \"require('./start-secure.js')\"",
    "validate": "node validate-startup.js",
    "start:safe": "npm run validate && node server.js",
    "dev:safe": "npm run validate && nodemon server.js",
    "test": "echo 'No tests specified' && exit 0",
    "lint": "echo 'No linting configured' && exit 0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "razorpay": "^2.9.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "cafe",
    "food-ordering",
    "restaurant",
    "nodejs",
    "express",
    "supabase",
    "razorpay"
  ],
  "author": "Ambis Cafe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohdajmal-prog/faheem.git"
  }
}
